# 现有配置 (Feishu + DB + TZ)
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/595c169e-5f9a-45a2-b922-b1d1021ba8b3
DB_PATH=/app/data/investment.db
REPORTS_PATH=/app/reports
TZ=Asia/Shanghai

# 推送可靠性
FEISHU_WEBHOOK_BACKUP=
FEISHU_MAX_RETRIES=3
FEISHU_RETRY_BACKOFF=0.5

# ── LLM 增强 (2026-06-19 新增) ──
# 不配 = 降级跳过, 公告流照常跑只是没有 LLM 摘要
# LLM_PROVIDER=glm      # glm | qwen | openai
# LLM_API_KEY=your_key
# LLM_MODEL=glm-4-flash  # 可选, 默认按 provider 选
# LLM_BASE_URL=          # 可选, 自定义端点
